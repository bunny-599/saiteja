# ==============================================================================
# Sky-Scrapper Config Credentials
# Copy this file to .env and fill in your actual API keys.
# ==============================================================================

# Anthropic Claude API Key (for competitor analysis and report generation)
# Obtain from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Serper API Key (for organic Google Search queries to find competitor details)
# Obtain from: https://serper.dev/ (1,000 free searches on signup)
SERPER_API_KEY=

# ScraperAPI Key (for rotating proxies and bypassing bot protection on Trustpilot, Growjo, LinkedIn)
# Obtain from: https://www.scraperapi.com/ (5,000 free requests on signup)
SCRAPERAPI_KEY=

# FastAPI Configuration
DATABASE_URL=sqlite+aiosqlite:///./sky_scrapper.db
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
